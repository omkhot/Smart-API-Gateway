{
  "title": "Smart API Gateway - Metrics Dashboard",
  "uid": "smart-api-gateway",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "5s",
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "panels": [
    {
      "id": 1,
      "title": "Request Rate by Route (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(spring_cloud_gateway_requests_seconds_count[1m])) by (routeId)",
          "legendFormat": "{{routeId}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "title": "Average Response Time by Route (s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(spring_cloud_gateway_requests_seconds_sum[1m])) by (routeId) / sum(rate(spring_cloud_gateway_requests_seconds_count[1m])) by (routeId)",
          "legendFormat": "{{routeId}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 3,
      "title": "Requests by Outcome (SUCCESS / CLIENT_ERROR / SERVER_ERROR)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(spring_cloud_gateway_requests_seconds_count[1m])) by (outcome)",
          "legendFormat": "{{outcome}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 4,
      "title": "Response Cache: Hit vs Miss (per second)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(rate(gateway_cache_requests_total[1m])) by (result)",
          "legendFormat": "{{result}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 5,
      "title": "Circuit Breaker State (1 = active)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "resilience4j_circuitbreaker_state",
          "legendFormat": "{{name}} - {{state}}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 6,
      "title": "Gateway JVM Heap Used (bytes)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "expr": "sum(jvm_memory_used_bytes{application=\"gateway-service\", area=\"heap\"}) by (id)",
          "legendFormat": "{{id}}",
          "refId": "A"
        }
      ]
    }
  ]
}
